#!/bin/bash

if [[ "$COLUMNS" == "" ]]; then
  COLUMNS=$(tput cols)
fi

function insertOptionalNewline() {
  exec < /dev/tty
  oldstty=$(stty -g)
  stty raw -echo min 0 2> /dev/null
  echo -en "\033[6n" > /dev/tty
  IFS=';' read -r -d R -a pos
  stty $oldstty
  if [[ "${pos[1]}" != "1" ]]; then
    printf "\n"
  fi
}

# Fork for performance
insertOptionalNewline &

shellType=$1
if [[ "$shellType" == "zsh" ]]; then
  esc="%%{"
  cse="%%}"
else
  esc="\["
  cse="\]"
fi

RESET="$esc\033[0m$cse"
RED="$esc\033[0;91m$cse"
GREEN="$esc\033[0;92m$cse"
YELLOW="$esc\033[0;93m$cse"
BLUE="$esc\033[0;94m$cse"
MAGENTA="$esc\033[0;95m$cse"
CYAN="$esc\033[0;96m$cse"
WHITE="$esc\033[0;97m$cse"

function hexToAnsi() {
  [[ "$1" =~ ^[0-9a-fA-F]{6}$ ]] || return
  local light=${2:-0}
  local r=$(( 16#${1:0:2} ))
  local g=$(( 16#${1:2:2} ))
  local b=$(( 16#${1:4:2} ))
  if [[ $light -gt 0 ]]; then
    r=$(( r + (255 - r) * light / 100 ))
    g=$(( g + (255 - g) * light / 100 ))
    b=$(( b + (255 - b) * light / 100 ))
  elif [[ $light -lt 0 ]]; then
    r=$(( r * (100 + light) / 100 ))
    g=$(( g * (100 + light) / 100 ))
    b=$(( b * (100 + light) / 100 ))
  fi
  echo "$esc\033[38;5;$((16+36*((r*5+127)/255)+6*((g*5+127)/255)+(b*5+127)/255))m$cse"
}

lineColor=$(hexToAnsi "$PROMPT_COLOR")
if [[ -n "$lineColor" ]]; then
  frameColor=$(hexToAnsi "$PROMPT_COLOR" -50)
else
  lineColor="$BLUE"
  frameColor="$CYAN"
fi

timeColor="$YELLOW"
infoColor="$YELLOW"
userColor="$GREEN"
pathColor="$MAGENTA"
alertColor="$RED"

line="$esc\342\224$cse\200"
cornerUL="$esc\342\225$cse\255"
cornerLL="$esc\342\225$cse\260"
cornerUR="$esc\342\225$cse\256"
cornerLR="$esc\342\225$cse\257"
cursorUp="$esc\033[1A$cse"
cursorDown="$esc\033[1B$cse"

frameBegin="$frameColor$line("
frameEnd="$frameColor)$line$lineColor"

if [[ -z "$PROMPT_USER" ]]; then
  PROMPT_USER="$USER@$HOSTNAME"
fi

topPrompt="$cursorUp$lineColor$cornerUL$frameBegin$userColor$PROMPT_USER$frameEnd$line"
padding=$(($COLUMNS - ${#PROMPT_USER} - 7))

if [[ -f "$HOME/.dotfiles_dirty" ]]; then
  topPrompt="$topPrompt$frameBegin$alertColor!$frameEnd$line"
  padding=$(($padding - 6))
fi

if [[ "$DEVENV" != "" ]]; then
  topPrompt="$topPrompt$frameBegin$infoColor$DEVENV$frameEnd$line"
  padding=$(($padding - ${#DEVENV} - 5))
fi

if [[ "${PWD:0:${#HOME}}" == "$HOME" ]]; then
  directory="~${PWD:${#HOME}}"
else
  directory="${PWD}"
fi
directoryLength=$((${#directory} + 4))

branch="$(git symbolic-ref HEAD 2>/dev/null)"
if [[ "$branch" != "" && $(($padding - ${#branch})) -gt 5 ]]; then
  branch=${branch##refs/heads/}
  branchPrompt="$frameBegin$pathColor$branch$frameEnd$line"
  padding=$(($padding - ${#branch} - 5))
else
  branchPrompt=""
fi

if [[ $padding -gt $directoryLength ]]; then
  for ((i=$directoryLength; i < $padding; i++)) {
    topPrompt="$topPrompt$line"
  }
  topPrompt="$topPrompt$branchPrompt$frameBegin$pathColor$directory$frameEnd"
else
  if [[ $padding -lt 8 ]]; then
    for ((i=0; i < padding; i++)) {
      topPrompt="$topPrompt$line"
    }
  else
    topPrompt="$topPrompt$branchPrompt$frameBegin$pathColor...${directory:$((7-$padding))}$frameEnd"
  fi
fi
topPrompt="$topPrompt$lineColor$cornerUR"

dateStr=$(date +"%Y-%m-%d")

rightPrompt="$frameBegin$timeColor$dateStr$frameEnd$cornerLR"

leftPrompt="$lineColor$cornerLL"
if [[ ! -z "$PROMPT_EXIT" && "$PROMPT_EXIT" != "0" ]]; then
  leftPrompt="$leftPrompt$frameBegin$alertColor$PROMPT_EXIT$frameEnd"
fi
timeStr=$(date +"%H:%M:%S")
leftPrompt="$leftPrompt$frameBegin$timeColor$timeStr$frameEnd$RESET "

# Wait for forked insertOptionalNewline
wait

if [[ "$shellType" == "zsh" ]]; then
  printf "\n$topPrompt\n$leftPrompt\t$rightPrompt$RESET"
else
  rightAlign="$esc\033[$(($COLUMNS - 14))G$cse"
  printf "\n$topPrompt\n$rightAlign$rightPrompt$cursorUp\n$leftPrompt"
fi
